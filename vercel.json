{
  "version": 2,
  "buildCommand": "",
  "installCommand": "cd api && npm install",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/v1/surahs",
      "dest": "/api/surahs.js"
    },
    {
      "src": "/api/v1/verses/(.*)",
      "dest": "/api/verses/$1.js"
    },
    {
      "src": "/api/v1/tafsir/generate",
      "dest": "/api/tafsir/generate.js"
    }
  ]
}